@{
    ViewData["Title"] = "P1 Reporting";
}

<div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-3">
    <div>
        <h1 class="h3 mb-1">P1 Reporting</h1>
        <div class="text-muted">Daily power consumption</div>
    </div>
    <div class="d-flex align-items-end gap-3">
        <div>
            <div class="form-label">Day</div>
            <div class="btn-group" role="group" aria-label="Report day navigation">
                <button id="previousDay" type="button" class="btn btn-outline-secondary">Previous</button>
                <button id="selectedDay" type="button" class="btn btn-outline-secondary" disabled></button>
                <button id="nextDay" type="button" class="btn btn-outline-secondary">Next</button>
            </div>
        </div>
        <div>
            <div class="form-label">Total consumed</div>
            <div id="dailyTotal" class="fs-5 fw-semibold">0.000 kWh</div>
        </div>
        <div>
            <div class="form-label">Total delivered back</div>
            <div id="dailyExportTotal" class="fs-5 fw-semibold">0.000 kWh</div>
        </div>
        <div>
            <div class="form-label">Net grid use</div>
            <div id="dailyNetTotal" class="fs-5 fw-semibold">0.000 kWh</div>
        </div>
        <div>
            <div class="form-label">Zonneopwek</div>
            <div id="dailySolarTotal" class="fs-5 fw-semibold">0.000 kWh</div>
        </div>
    </div>
</div>

<h2 class="h5 mb-2">Consumption and delivery</h2>
<div style="height:55vh; min-height:320px;">
    <canvas id="dailyConsumptionChart" style="width:100%; height:100%;"></canvas>
</div>

<h2 class="h5 mt-4 mb-2">Stroom van en naar het net</h2>
<div style="height:45vh; min-height:280px;">
    <canvas id="netEnergyFlowChart" style="width:100%; height:100%;"></canvas>
</div>

<h2 class="h5 mt-4 mb-2">Zonneenergie opgewekt</h2>
<div style="height:45vh; min-height:280px;">
    <canvas id="solarProductionChart" style="width:100%; height:100%;"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
    const previousDay = document.getElementById('previousDay');
    const selectedDay = document.getElementById('selectedDay');
    const nextDay = document.getElementById('nextDay');
    const dailyTotal = document.getElementById('dailyTotal');
    const dailyExportTotal = document.getElementById('dailyExportTotal');
    const dailyNetTotal = document.getElementById('dailyNetTotal');
    const dailySolarTotal = document.getElementById('dailySolarTotal');
    const chartCanvas = document.getElementById('dailyConsumptionChart');
    const netFlowCanvas = document.getElementById('netEnergyFlowChart');
    const solarProductionCanvas = document.getElementById('solarProductionChart');
    const today = new Date();
    let activeDate = new Date(today.getFullYear(), today.getMonth(), today.getDate());

    function toDateKey(date) {
        const localDate = new Date(date.getTime() - (date.getTimezoneOffset() * 60000));
        return localDate.toISOString().slice(0, 10);
    }

    function setSelectedDayText(date) {
        selectedDay.textContent = date.toLocaleDateString(undefined, {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric'
        });
    }

    function moveDay(offset) {
        activeDate = new Date(activeDate.getFullYear(), activeDate.getMonth(), activeDate.getDate() + offset);
        setSelectedDayText(activeDate);
        loadReport(toDateKey(activeDate)).catch(error => {
            console.error(error);
        });
    }

    function isCheaperTariffPeriod(label) {
        return label >= '12:00' && label < '16:00';
    }

    function gridConsumptionColor(label) {
        return isCheaperTariffPeriod(label)
            ? 'rgba(248, 150, 159, 0.75)'
            : 'rgba(220, 53, 69, 0.75)';
    }

    function gridConsumptionBorderColor(label) {
        return isCheaperTariffPeriod(label)
            ? 'rgba(248, 150, 159, 1)'
            : 'rgba(220, 53, 69, 1)';
    }

    const cheaperTariffBackgroundPlugin = {
        id: 'cheaperTariffBackground',
        beforeDatasetsDraw: function (chart) {
            const xScale = chart.scales.x;
            const chartArea = chart.chartArea;
            if (!xScale || !chartArea) {
                return;
            }

            const startIndex = chart.data.labels.indexOf('12:00');
            const endIndex = chart.data.labels.indexOf('16:00');
            if (startIndex < 0 || endIndex < 0) {
                return;
            }

            const bucketWidth = xScale.getPixelForValue(startIndex + 1) - xScale.getPixelForValue(startIndex);
            const left = xScale.getPixelForValue(startIndex) - (bucketWidth / 2);
            const right = xScale.getPixelForValue(endIndex) - (bucketWidth / 2);
            const context = chart.ctx;

            context.save();
            context.fillStyle = 'rgba(220, 220, 220, 0.45)';
            context.fillRect(left, chartArea.top, right - left, chartArea.bottom - chartArea.top);
            context.restore();
        }
    };

    const chart = new Chart(chartCanvas, {
        type: 'bar',
        plugins: [cheaperTariffBackgroundPlugin],
        data: {
            labels: [],
            datasets: [{
                type: 'bar',
                label: 'Consumption (kWh)',
                data: [],
                backgroundColor: function (context) {
                    return gridConsumptionColor(context.raw?.x);
                },
                borderColor: function (context) {
                    return gridConsumptionBorderColor(context.raw?.x);
                },
                borderWidth: 1,
                stack: 'energy'
            }, {
                type: 'line',
                label: 'Delivered back (kWh)',
                data: [],
                borderColor: 'rgba(144, 238, 144, 1)',
                backgroundColor: 'rgba(144, 238, 144, 0.2)',
                borderWidth: 2,
                pointRadius: 0,
                pointHoverRadius: 3,
                tension: 0.25,
                fill: false
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            interaction: {
                intersect: false,
                mode: 'index'
            },
            scales: {
                x: {
                    stacked: true,
                    ticks: {
                        autoSkip: false,
                        maxRotation: 0,
                        callback: function (value, index) {
                            const label = this.getLabelForValue(value);
                            return index % 4 === 0 ? label : '';
                        }
                    },
                    title: {
                        display: true,
                        text: 'Time'
                    }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'kWh'
                    }
                }
            },
            plugins: {
                legend: {
                    display: true
                },
                tooltip: {
                    callbacks: {
                        label: function (context) {
                            const bucket = context.raw;
                            const label = context.dataset.label || 'Value';
                            if (!bucket || bucket.y === null) {
                                return `${label}: no data`;
                            }

                            return `${label}: ${bucket.y.toFixed(3)} kWh`;
                        },
                        afterLabel: function (context) {
                            const bucket = context.raw;
                            if (bucket && bucket.hasData && !bucket.isReliable) {
                                return 'Marked unreliable';
                            }

                            return '';
                        }
                    }
                }
            }
        }
    });

    const netFlowChart = new Chart(netFlowCanvas, {
        type: 'bar',
        plugins: [cheaperTariffBackgroundPlugin],
        data: {
            labels: [],
            datasets: [{
                type: 'bar',
                label: 'Van het net (kWh)',
                data: [],
                backgroundColor: function (context) {
                    return gridConsumptionColor(context.raw?.x);
                },
                borderColor: function (context) {
                    return gridConsumptionBorderColor(context.raw?.x);
                },
                borderWidth: 1,
                yAxisID: 'energy',
                order: 2
            }, {
                type: 'bar',
                label: 'Teruggeleverd (kWh)',
                data: [],
                backgroundColor: 'rgba(25, 135, 84, 0.75)',
                borderColor: 'rgba(25, 135, 84, 1)',
                borderWidth: 1,
                yAxisID: 'energy',
                order: 2
            }, {
                type: 'line',
                label: 'Gemiddeld vermogen (W)',
                data: [],
                borderColor: 'rgba(13, 110, 253, 1)',
                backgroundColor: 'rgba(13, 110, 253, 0.15)',
                borderWidth: 2,
                pointRadius: 0,
                pointHoverRadius: 3,
                tension: 0.2,
                yAxisID: 'power',
                order: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            interaction: {
                intersect: false,
                mode: 'index'
            },
            scales: {
                x: {
                    stacked: true,
                    ticks: {
                        autoSkip: false,
                        maxRotation: 0,
                        callback: function (value, index) {
                            const label = this.getLabelForValue(value);
                            return index % 4 === 0 ? label : '';
                        }
                    },
                    title: {
                        display: true,
                        text: 'Time'
                    }
                },
                energy: {
                    type: 'linear',
                    position: 'left',
                    stacked: true,
                    title: {
                        display: true,
                        text: 'kWh per 15 minuten'
                    }
                },
                power: {
                    type: 'linear',
                    position: 'right',
                    grid: {
                        drawOnChartArea: false
                    },
                    title: {
                        display: true,
                        text: 'Gemiddeld W'
                    }
                }
            },
            plugins: {
                legend: {
                    display: true
                },
                tooltip: {
                    callbacks: {
                        label: function (context) {
                            const bucket = context.raw;
                            const label = context.dataset.label || 'Value';
                            if (!bucket || bucket.y === null) {
                                return `${label}: no data`;
                            }

                            if (context.dataset.yAxisID === 'power') {
                                return `${label}: ${bucket.y.toFixed(0)} W`;
                            }

                            return `${label}: ${Math.abs(bucket.y).toFixed(3)} kWh`;
                        },
                        afterBody: function (items) {
                            const bucket = items.length > 0 ? items[0].raw : null;
                            if (!bucket || !bucket.hasData) {
                                return '';
                            }

                            const lines = [`Netto verbruik: ${bucket.netKwh.toFixed(3)} kWh`];
                            if (!bucket.isReliable) {
                                lines.push('Marked unreliable');
                            }

                            return lines;
                        }
                    }
                }
            }
        }
    });

    const solarProductionChart = new Chart(solarProductionCanvas, {
        type: 'bar',
        data: {
            labels: [],
            datasets: [{
                type: 'bar',
                label: 'Opgewekt (kWh)',
                data: [],
                backgroundColor: 'rgba(255, 193, 7, 0.75)',
                borderColor: 'rgba(255, 193, 7, 1)',
                borderWidth: 1,
                yAxisID: 'energy',
                order: 2
            }, {
                type: 'line',
                label: 'Gemiddeld vermogen (W)',
                data: [],
                borderColor: 'rgba(253, 126, 20, 1)',
                backgroundColor: 'rgba(253, 126, 20, 0.15)',
                borderWidth: 2,
                pointRadius: 0,
                pointHoverRadius: 3,
                tension: 0.2,
                yAxisID: 'power',
                order: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            interaction: {
                intersect: false,
                mode: 'index'
            },
            scales: {
                x: {
                    ticks: {
                        autoSkip: false,
                        maxRotation: 0,
                        callback: function (value, index) {
                            const label = this.getLabelForValue(value);
                            return index % 4 === 0 ? label : '';
                        }
                    },
                    title: {
                        display: true,
                        text: 'Time'
                    }
                },
                energy: {
                    type: 'linear',
                    position: 'left',
                    beginAtZero: true,
                    title: {
                        display: true,
                        text: 'kWh per 15 minuten'
                    }
                },
                power: {
                    type: 'linear',
                    position: 'right',
                    beginAtZero: true,
                    grid: {
                        drawOnChartArea: false
                    },
                    title: {
                        display: true,
                        text: 'Gemiddeld W'
                    }
                }
            },
            plugins: {
                legend: {
                    display: true
                },
                tooltip: {
                    callbacks: {
                        label: function (context) {
                            const bucket = context.raw;
                            const label = context.dataset.label || 'Value';
                            if (!bucket || bucket.y === null) {
                                return `${label}: geen data`;
                            }

                            if (context.dataset.yAxisID === 'power') {
                                return `${label}: ${bucket.y.toFixed(0)} W`;
                            }

                            return `${label}: ${bucket.y.toFixed(3)} kWh`;
                        },
                        afterBody: function (items) {
                            const bucket = items.length > 0 ? items[0].raw : null;
                            if (!bucket || !bucket.hasSolarData || bucket.isSolarReliable) {
                                return '';
                            }

                            return 'Gemarkeerd als onbetrouwbaar';
                        }
                    }
                }
            }
        }
    });

    async function loadReport(date) {
        const response = await fetch(`/p1-reporting/data?date=${encodeURIComponent(date)}`);
        if (!response.ok) {
            throw new Error(`Daily report request failed with HTTP ${response.status}`);
        }

        const report = await response.json();
        const buckets = report.buckets.map(bucket => ({
            label: bucket.label,
            consumptionKwh: bucket.consumptionKwh === null ? null : Number(bucket.consumptionKwh),
            exportKwh: bucket.exportKwh === null ? null : Number(bucket.exportKwh),
            netKwh: bucket.netKwh === null ? null : Number(bucket.netKwh),
            averagePowerW: bucket.averagePowerW === null ? null : Number(bucket.averagePowerW),
            solarProductionKwh: bucket.solarProductionKwh === null ? null : Number(bucket.solarProductionKwh),
            averageSolarPowerW: bucket.averageSolarPowerW === null ? null : Number(bucket.averageSolarPowerW),
            hasData: bucket.hasData,
            isReliable: bucket.isReliable,
            hasSolarData: bucket.hasSolarData,
            isSolarReliable: bucket.isSolarReliable
        }));

        chart.data.labels = report.buckets.map(bucket => bucket.label);
        chart.data.datasets[0].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.consumptionKwh,
            hasData: bucket.hasData,
            isReliable: bucket.isReliable
        }));
        chart.data.datasets[1].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.exportKwh,
            hasData: bucket.hasData,
            isReliable: bucket.isReliable
        }));

        netFlowChart.data.labels = buckets.map(bucket => bucket.label);
        netFlowChart.data.datasets[0].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.consumptionKwh,
            netKwh: bucket.netKwh,
            hasData: bucket.hasData,
            isReliable: bucket.isReliable
        }));
        netFlowChart.data.datasets[1].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.exportKwh === null ? null : -bucket.exportKwh,
            netKwh: bucket.netKwh,
            hasData: bucket.hasData,
            isReliable: bucket.isReliable
        }));
        netFlowChart.data.datasets[2].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.averagePowerW,
            netKwh: bucket.netKwh,
            hasData: bucket.hasData,
            isReliable: bucket.isReliable
        }));

        solarProductionChart.data.labels = buckets.map(bucket => bucket.label);
        solarProductionChart.data.datasets[0].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.solarProductionKwh,
            hasSolarData: bucket.hasSolarData,
            isSolarReliable: bucket.isSolarReliable
        }));
        solarProductionChart.data.datasets[1].data = buckets.map(bucket => ({
            x: bucket.label,
            y: bucket.averageSolarPowerW,
            hasSolarData: bucket.hasSolarData,
            isSolarReliable: bucket.isSolarReliable
        }));

        const totalConsumptionKwh = Number(report.totalConsumptionKwh);
        const totalExportKwh = Number(report.totalExportKwh);
        const totalNetKwh = totalConsumptionKwh - totalExportKwh;
        const totalSolarProductionKwh = Number(report.totalSolarProductionKwh);
        dailyTotal.textContent = `${Number(report.totalConsumptionKwh).toFixed(3)} kWh`;
        dailyExportTotal.textContent = `${Number(report.totalExportKwh).toFixed(3)} kWh`;
        dailyNetTotal.textContent = `${totalNetKwh.toFixed(3)} kWh`;
        dailySolarTotal.textContent = `${totalSolarProductionKwh.toFixed(3)} kWh`;
        chart.update();
        netFlowChart.update();
        solarProductionChart.update();
    }

    previousDay.addEventListener('click', function () {
        moveDay(-1);
    });

    nextDay.addEventListener('click', function () {
        moveDay(1);
    });

    setSelectedDayText(activeDate);
    loadReport(toDateKey(activeDate)).catch(error => {
        console.error(error);
    });
})();
</script>
