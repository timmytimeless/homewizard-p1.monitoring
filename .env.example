# Example environment variables for local development.
# DO NOT commit real credentials. Use your CI/host secret manager for production.
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:3000
DataProtection__KeysPath=./data-protection-keys
ConnectionStrings__Identity=Server=<mariadb-host>;Port=3306;Database=<database>;User=<app-user>;Password=<db-password>;
MariaDb__ServerVersion=10.11.0
HW_IP=your-homewizard-ip
HW_SCHEME=wss
HomeWizard__CertificateSha256=
