ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:3000
DataProtection__KeysPath=/var/aiterate-energy/data-protection-keys

ConnectionStrings__Identity=Server=<mariadb-host>;Port=3306;Database=<database>;User=<app-user>;Password=<db-password>;
MariaDb__ServerVersion=10.11.0

HW_IP=your-homewizard-ip
HW_SCHEME=wss
HomeWizard__CertificateSha256=your-homewizard-certificate-sha256

HomeWizardCollector__Scheme=https
HomeWizardCollector__Host=your-homewizard-ip
HomeWizardCollector__PollIntervalSeconds=60
HomeWizardCollector__BucketMinutes=15
# Prefer setting this for the dedicated collector. If omitted, the collector
# falls back to the encrypted token stored in AspNetUsers.HomeWizardP1Token.
HomeWizardCollector__Token=your-homewizard-p1-token
